<!DOCTYPE html>
<html lang="bg">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TodorovNET — Admin</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{--bg:#060608;--bg2:#0d0d10;--bg3:#121215;--bg4:#18181c;--b1:#1a1a20;--b2:#252530;--b3:#333340;--or:#f97316;--or2:#ea6a08;--w:#f0f0f5;--w2:#c8c8d8;--g1:#9090a8;--g2:#55556a;--g3:#2a2a38;--gr:#22c55e;--re:#ef4444;--bl:#3b82f6;--ye:#f59e0b;--go:#fbbf24;--pu:#a855f7}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--w);font-family:'Barlow',sans-serif;height:100vh;overflow:hidden}
/* LOGIN */
.login-screen{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:1000;background:var(--bg)}
.login-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%,rgba(249,115,22,.05),transparent 70%);pointer-events:none}
.login-card{width:340px;position:relative;z-index:1}
.login-logo{text-align:center;margin-bottom:28px}
.login-logo-box{width:52px;height:52px;background:var(--or);border-radius:14px;display:inline-flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:900;color:#fff;box-shadow:0 0 40px rgba(249,115,22,.3);margin-bottom:10px}
.login-title{font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:900;text-transform:uppercase;letter-spacing:.05em}
.login-title em{color:var(--or);font-style:normal}
.login-sub{font-size:11px;color:var(--g2);margin-top:3px}
.lcard{background:var(--bg2);border:1px solid var(--b1);border-radius:14px;padding:24px}
.lcard .fg{margin-bottom:14px}
.lcard label{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--g2);display:block;margin-bottom:4px}
.lcard input{width:100%;background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:10px 12px;color:var(--w);font-size:13.5px;font-family:'Barlow',sans-serif;outline:none;transition:border-color .12s}
.lcard input:focus{border-color:var(--or)}
.login-btn{width:100%;padding:11px;background:var(--or);border:none;border-radius:9px;color:#fff;font-size:13px;font-weight:800;cursor:pointer;font-family:'Barlow',sans-serif;text-transform:uppercase;letter-spacing:.07em;transition:.12s;margin-top:4px}
.login-btn:hover{background:var(--or2)}
.login-err{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);color:var(--re);border-radius:8px;padding:8px 12px;font-size:12px;font-weight:700;margin-top:10px;display:none}
/* APP */
.app{display:grid;grid-template-columns:210px 1fr;height:100vh;overflow:hidden;display:none}
.sb{background:var(--bg2);border-right:1px solid var(--b1);display:flex;flex-direction:column;overflow:hidden}
.sb-logo{padding:14px 12px;border-bottom:1px solid var(--b1);flex-shrink:0}
.logo-mark{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.logo-ic{width:30px;height:30px;background:var(--or);border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:900;color:#fff;box-shadow:0 0 16px rgba(249,115,22,.3);flex-shrink:0}
.logo-text{font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:900;text-transform:uppercase;letter-spacing:.04em}
.logo-text em{color:var(--or);font-style:normal}
.ep{background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:7px 10px;cursor:pointer}
.ep-name{font-size:11px;font-weight:700;color:var(--w2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.ep-meta{font-size:9px;color:var(--g2);display:flex;align-items:center;gap:4px}
.ldot{width:5px;height:5px;border-radius:50%;background:var(--re);animation:pulse 1.2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.8);opacity:.4}}
.sb-nav{flex:1;overflow-y:auto;padding:6px 0;scrollbar-width:none}
.sb-nav::-webkit-scrollbar{display:none}
.ns{padding:9px 12px 3px;font-size:8px;font-weight:800;text-transform:uppercase;letter-spacing:.18em;color:var(--g3)}
.ni{display:flex;align-items:center;gap:8px;padding:7px 9px;margin:1px 5px;border-radius:8px;cursor:pointer;transition:.12s;font-size:12px;font-weight:600;color:var(--g1);position:relative}
.ni:hover{background:var(--bg3);color:var(--w2)}
.ni.act{background:rgba(249,115,22,.08);color:var(--or)}
.ni.act::before{content:'';position:absolute;left:-5px;top:25%;bottom:25%;width:3px;background:var(--or);border-radius:0 3px 3px 0}
.ni-ic{font-size:14px;width:17px;text-align:center;flex-shrink:0}
.ni-bd{font-size:9px;font-weight:900;padding:2px 5px;border-radius:7px;flex-shrink:0;margin-left:auto}
.bd-r{background:rgba(239,68,68,.12);color:var(--re)}.bd-o{background:rgba(249,115,22,.12);color:var(--or)}
.sb-foot{padding:9px 12px;border-top:1px solid var(--b1);flex-shrink:0;display:flex;align-items:center;gap:8px}
.conn-b{display:flex;align-items:center;gap:5px;font-size:10px;font-weight:700;color:var(--g2)}
.cdot{width:7px;height:7px;border-radius:50%;background:var(--g2);transition:.3s}
.cdot.on{background:var(--gr);box-shadow:0 0 6px rgba(34,197,94,.5)}
.logout-btn{margin-left:auto;font-size:10px;color:var(--g2);cursor:pointer;font-weight:700;padding:4px 8px;border-radius:6px;border:1px solid var(--b2);background:var(--bg3);transition:.12s;font-family:'Barlow',sans-serif}
.logout-btn:hover{color:var(--re);border-color:rgba(239,68,68,.3)}
.main{display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{height:48px;background:rgba(6,6,8,.97);border-bottom:1px solid var(--b1);display:flex;align-items:center;padding:0 16px;gap:10px;flex-shrink:0}
.tb-title{font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:900;text-transform:uppercase;letter-spacing:.07em;flex:1}
.tbb{height:30px;padding:0 12px;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;transition:.12s;border:1px solid var(--b2);background:var(--bg3);color:var(--g1);white-space:nowrap;font-family:'Barlow',sans-serif;text-transform:uppercase;letter-spacing:.05em}
.tbb:hover{background:var(--bg4);color:var(--w)}.tbb.pr{background:var(--or);border-color:var(--or);color:#fff}.tbb.pr:hover{background:var(--or2)}
.content{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--b3) transparent}
.content::-webkit-scrollbar{width:4px}.content::-webkit-scrollbar-thumb{background:var(--b3);border-radius:2px}
.pg{display:none;animation:fadeIn .18s ease both;padding:16px}
.pg.act{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.card{background:var(--bg2);border:1px solid var(--b1);border-radius:12px;overflow:hidden;margin-bottom:12px}
.ch{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid var(--b1)}
.ct{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.16em;color:var(--g2);display:flex;align-items:center;gap:6px}
.ca{font-size:10px;color:var(--or);font-weight:700;cursor:pointer;text-transform:uppercase;letter-spacing:.06em}
.ca:hover{color:var(--w)}
table{width:100%;border-collapse:collapse}
th{padding:7px 11px;text-align:left;font-size:8px;font-weight:800;text-transform:uppercase;letter-spacing:.15em;color:var(--g3);border-bottom:1px solid var(--b1);background:var(--bg3);white-space:nowrap}
th.r{text-align:right}
td{padding:8px 11px;border-bottom:1px solid var(--b1);font-size:12px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr.gold td{background:linear-gradient(90deg,rgba(251,191,36,.04),transparent)}
tr.silver td{background:linear-gradient(90deg,rgba(192,192,192,.025),transparent)}
tr.bronze td{background:linear-gradient(90deg,rgba(205,127,50,.025),transparent)}
.pos{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:900;text-align:center;width:26px}
.pos.g{color:var(--go)}.pos.s{color:#C0C0C0}.pos.b{color:#CD7F32}.pos.x{color:var(--g3);font-size:15px}
.rn{display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:21px;border-radius:4px;font-family:'Share Tech Mono',monospace;font-size:11px;font-weight:700;border:1.5px solid;padding:0 4px;background:#111;color:#ddd;border-color:#444}
.mo{font-family:'Share Tech Mono',monospace;font-weight:700}
.mo.nav{color:var(--bl)}.mo.xc{color:var(--or)}.mo.ss{color:var(--pu)}.mo.pen{color:var(--re)}.mo.total{font-size:13px;color:var(--or)}
.badge{display:inline-flex;align-items:center;padding:2px 6px;border-radius:4px;font-size:9px;font-weight:900;text-transform:uppercase;border:1px solid}
.badge.ok{background:rgba(34,197,94,.07);color:var(--gr);border-color:rgba(34,197,94,.2)}
.badge.dnf{background:rgba(239,68,68,.07);color:var(--re);border-color:rgba(239,68,68,.2)}
.badge.dns{background:rgba(100,116,139,.07);color:#64748b;border-color:rgba(100,116,139,.15)}
.badge.dsq{background:rgba(168,85,247,.07);color:var(--pu);border-color:rgba(168,85,247,.2)}
.badge.pen{background:rgba(245,158,11,.07);color:var(--ye);border-color:rgba(245,158,11,.2)}
.badge.conf{background:rgba(34,197,94,.07);color:var(--gr);border-color:rgba(34,197,94,.2)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px}
.stat{background:var(--bg2);border:1px solid var(--b1);border-radius:11px;padding:12px 14px;position:relative;overflow:hidden}
.stat::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.stat.or::after{background:var(--or)}.stat.gr::after{background:var(--gr)}.stat.re::after{background:var(--re)}.stat.bl::after{background:var(--bl)}
.stat-val{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:900;line-height:1;margin-bottom:2px}
.stat-label{font-size:9px;color:var(--g2);text-transform:uppercase;letter-spacing:.09em}
.fgrid2{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:9px}
.fgrid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:9px}
.fg label{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--g2);display:block;margin-bottom:4px}
.fg input,.fg select,.fg textarea{width:100%;background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:8px 11px;color:var(--w);font-size:12.5px;font-family:'Barlow',sans-serif;outline:none;transition:border-color .12s}
.fg input:focus,.fg select:focus{border-color:var(--or)}
.fg input.mono{font-family:'Share Tech Mono',monospace}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:5px;padding:8px 15px;border-radius:8px;font-size:11px;font-weight:800;cursor:pointer;border:none;text-transform:uppercase;letter-spacing:.07em;transition:.12s;font-family:'Barlow',sans-serif}
.btn.pr{background:var(--or);color:#fff}.btn.pr:hover{background:var(--or2)}
.btn.sc{background:var(--bg3);color:var(--g1);border:1px solid var(--b2)}.btn.sc:hover{background:var(--bg4);color:var(--w)}
.btn.gr{background:rgba(34,197,94,.1);color:var(--gr);border:1px solid rgba(34,197,94,.2)}.btn.gr:hover{background:rgba(34,197,94,.18)}
.btn.re{background:rgba(239,68,68,.1);color:var(--re);border:1px solid rgba(239,68,68,.2)}.btn.re:hover{background:rgba(239,68,68,.18)}
.btn.sm{padding:4px 9px;font-size:10px;border-radius:6px}
.brow{display:flex;gap:7px;flex-wrap:wrap;margin-top:10px}
.msg{padding:8px 12px;border-radius:8px;font-size:12px;font-weight:700;margin-top:8px;display:none}
.msg.ok{background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);color:var(--gr);display:flex}
.msg.err{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);color:var(--re);display:flex}
.toast{position:fixed;bottom:16px;right:16px;background:var(--bg3);border:1px solid var(--b2);color:var(--w);padding:9px 15px;border-radius:10px;font-size:12px;font-weight:700;z-index:9999;opacity:0;transition:.25s;pointer-events:none;max-width:280px;box-shadow:0 8px 28px rgba(0,0,0,.5)}
.toast.show{opacity:1}
.flag-bar{display:flex;gap:6px;padding:10px 14px;border-bottom:1px solid var(--b1);align-items:center;flex-wrap:wrap}
.flag-label{font-size:9px;color:var(--g2);text-transform:uppercase;letter-spacing:.1em;margin-right:3px}
.fbtn{padding:5px 12px;border-radius:7px;font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:.07em;cursor:pointer;border:1.5px solid;transition:.13s;font-family:'Barlow',sans-serif}
.fbtn.green{background:rgba(34,197,94,.06);color:var(--gr);border-color:rgba(34,197,94,.2)}.fbtn.yellow{background:rgba(245,158,11,.06);color:var(--ye);border-color:rgba(245,158,11,.2)}.fbtn.red{background:rgba(239,68,68,.06);color:var(--re);border-color:rgba(239,68,68,.2)}.fbtn.black{background:rgba(0,0,0,.3);color:#aaa;border-color:#444}
.fbtn:hover{filter:brightness(1.2);transform:translateY(-1px)}.fbtn.active{filter:brightness(1.3);transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.3)}
.mode-tabs{display:flex;background:var(--bg3);border:1px solid var(--b2);border-radius:9px;padding:3px;margin-bottom:12px;overflow-x:auto}
.mtab{flex:1;padding:6px 11px;border-radius:7px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;cursor:pointer;text-align:center;transition:.13s;color:var(--g2);white-space:nowrap}
.mtab.act{background:var(--bg2);color:var(--w);box-shadow:0 1px 4px rgba(0,0,0,.4)}
.npwrap{background:var(--bg3);border:1px solid var(--b2);border-radius:12px;padding:13px}
.npd{background:var(--bg2);border:1px solid var(--b2);border-radius:9px;padding:11px;text-align:center;margin-bottom:10px}
.np-rider{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:900;text-transform:uppercase;color:var(--or);margin-bottom:2px;letter-spacing:.04em}
.np-time{font-family:'Share Tech Mono',monospace;font-size:34px;font-weight:700;color:var(--w);letter-spacing:.06em;line-height:1}
.np-time.empty{color:var(--g3)}
.np-hint{font-size:8px;color:var(--g2);margin-top:2px;text-transform:uppercase;letter-spacing:.1em}
.npgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-bottom:7px}
.npb{background:var(--bg2);border:1px solid var(--b2);border-radius:8px;padding:11px 5px;font-family:'Share Tech Mono',monospace;font-size:17px;font-weight:700;color:var(--w);cursor:pointer;transition:.1s;display:flex;align-items:center;justify-content:center;user-select:none}
.npb:hover,.npb:active{background:var(--bg4)}
.npb.del{font-size:13px;color:var(--g2)}.npb.clr{background:rgba(239,68,68,.05);border-color:rgba(239,68,68,.14);color:var(--re);font-size:9px;font-family:'Barlow',sans-serif;font-weight:900;text-transform:uppercase}
.npb.ok{background:var(--or);border-color:var(--or);color:#fff;font-size:11px;font-family:'Barlow Condensed',sans-serif;font-weight:900;text-transform:uppercase;letter-spacing:.07em;grid-column:span 2}
.npb.ok:hover{background:var(--or2)}
.st-btns{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-top:6px}
.stb{background:var(--bg3);border:1px solid var(--b2);border-radius:7px;padding:6px;font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:.05em;cursor:pointer;text-align:center;transition:.13s;font-family:'Barlow',sans-serif}
.stb:hover{background:var(--bg4)}.stb.dnf{color:var(--re);border-color:rgba(239,68,68,.2)}.stb.dns{color:var(--g2)}.stb.dsq{color:var(--pu);border-color:rgba(168,85,247,.2)}
.rs-wrap{position:relative;margin-bottom:8px}
.rs-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--g2);font-size:13px;pointer-events:none}
.rs-wrap input{padding-left:32px}
.rs-drop{position:absolute;top:100%;left:0;right:0;z-index:100;background:var(--bg3);border:1px solid var(--b2);border-radius:8px;margin-top:3px;max-height:170px;overflow-y:auto;display:none}
.rs-item{padding:8px 12px;cursor:pointer;font-size:12px;display:flex;align-items:center;gap:8px}
.rs-item:hover{background:var(--bg4)}
.row{display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap}
.col{flex:1;min-width:220px}
.sl{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:var(--g2);margin-bottom:8px;display:flex;align-items:center;gap:8px}
.sl::after{content:'';flex:1;height:1px;background:var(--b1)}
.empty-cell{text-align:center;color:var(--g2);padding:28px}
</style>
</head>
<body>

<!-- LOGIN -->
<div class="login-screen" id="login-screen">
  <div class="login-bg"></div>
  <div class="login-card">
    <div class="login-logo">
      <div class="login-logo-box">T</div>
      <div class="login-title">Todo<em>r</em>ovNET</div>
      <div class="login-sub">Admin панел · Организатори</div>
    </div>
    <div class="lcard">
      <div class="fg"><label>Потребителско Иme</label><input id="l-user" type="text" placeholder="admin" autocomplete="username"></div>
      <div class="fg"><label>Парола</label><input id="l-pass" type="password" placeholder="••••••••" autocomplete="current-password"></div>
      <button class="login-btn" onclick="doLogin()">🔐 Вход в системата</button>
      <div class="login-err" id="l-err">Грешно потребителско име или парола.</div>
    </div>
  </div>
</div>

<!-- APP -->
<div class="app" id="app">
  <aside class="sb">
    <div class="sb-logo">
      <div class="logo-mark">
        <div class="logo-ic">T</div>
        <div class="logo-text">Todo<em>r</em>ovNET</div>
      </div>
      <div class="ep" onclick="nav('standings')">
        <div class="ep-name" id="sb-ev">Зареждане...</div>
        <div class="ep-meta"><div class="ldot"></div><span id="sb-loc">—</span></div>
      </div>
    </div>
    <nav class="sb-nav">
      <div class="ns">Live</div>
      <div class="ni act" onclick="nav('standings')"><div class="ni-ic">🏆</div>Класация<div class="ni-bd bd-o" id="sb-cnt">—</div></div>
      <div class="ni" onclick="nav('timing')"><div class="ni-ic">⏱️</div>Въвеждане</div>
      <div class="ns">Управление</div>
      <div class="ni" onclick="nav('riders')"><div class="ni-ic">🏍️</div>Участници</div>
      <div class="ni" onclick="nav('add-rider')"><div class="ni-ic">➕</div>Нов Участник</div>
      <div class="ni" onclick="nav('penalties')"><div class="ni-ic">⚠️</div>Наказания<div class="ni-bd bd-r" id="sb-pen" style="display:none">0</div></div>
      <div class="ni" onclick="nav('events')"><div class="ni-ic">📅</div>Събития</div>
      <div class="ns">Публично</div>
      <div class="ni" onclick="window.open('index.html','_blank')"><div class="ni-ic">🌐</div>Публична Страница</div>
    </nav>
    <div class="sb-foot">
      <div class="conn-b"><div class="cdot" id="cdot"></div><span id="ct" style="font-size:10px;color:var(--g1)">—</span></div>
      <div class="logout-btn" onclick="logout()">Изход</div>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="tb-title" id="tb-title">🏆 Класация</div>
      <div style="display:flex;gap:6px">
        <div class="tbb" onclick="loadStandings()">⟳</div>
        <div class="tbb pr" onclick="nav('timing')">⏱️ Въведи Резултат</div>
      </div>
    </header>
    <div class="content">

      <!-- STANDINGS -->
      <div class="pg act" id="pg-standings">
        <div class="stats-grid">
          <div class="stat or"><div class="stat-val" id="s-fin">—</div><div class="stat-label">Финишираха</div></div>
          <div class="stat re"><div class="stat-val" id="s-dnx">—</div><div class="stat-label">DNS / DNF</div></div>
          <div class="stat bl"><div class="stat-val" id="s-tot">—</div><div class="stat-label">Общо</div></div>
          <div class="stat gr"><div class="stat-val" id="s-pen">—</div><div class="stat-label">Наказания</div></div>
        </div>
        <div class="card">
          <div class="flag-bar">
            <div class="flag-label">Знаме:</div>
            <div class="fbtn green active" id="flag-Green" onclick="setFlag('Green')">🟢 Зелено</div>
            <div class="fbtn yellow" id="flag-Yellow" onclick="setFlag('Yellow')">🟡 Жълто</div>
            <div class="fbtn red" id="flag-Red" onclick="setFlag('Red')">🔴 Червено</div>
            <div class="fbtn black" id="flag-Black" onclick="setFlag('Black')">⬛ Черно</div>
            <div style="margin-left:auto;font-size:10px;color:var(--g2)" id="last-up">—</div>
          </div>
          <div style="overflow-x:auto">
            <table>
              <thead><tr><th style="width:32px">#</th><th style="width:42px">№</th><th>Участник</th><th class="r">Nav</th><th class="r">XC</th><th class="r">SS</th><th class="r">Пен.</th><th class="r">Общо</th><th>Статус</th></tr></thead>
              <tbody id="st-body"><tr><td colspan="9" class="empty-cell">Зареждане...</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- TIMING -->
      <div class="pg" id="pg-timing">
        <div class="mode-tabs">
          <div class="mtab act" onclick="setTMode('nav',this)">🧭 Навигация</div>
          <div class="mtab" onclick="setTMode('xc',this)">🏁 XC Обиколка</div>
          <div class="mtab" onclick="setTMode('ss',this)">⏱️ Спец. Участък</div>
        </div>
        <div class="row">
          <div class="col" style="max-width:320px">
            <div id="tmode-lbl" style="background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.14);border-radius:8px;padding:7px 11px;margin-bottom:10px;font-size:11px;color:var(--bl);font-weight:700">🧭 Режим: Навигация</div>
            <div class="npwrap">
              <div class="rs-wrap"><div class="rs-icon">🔍</div><input id="t-search" placeholder="Номер или иme..." oninput="searchR(this.value,'t')" autocomplete="off"><div class="rs-drop" id="t-drop"></div></div>
              <div class="npd"><div class="np-rider" id="np-r">#— · Избери</div><div class="np-time empty" id="np-t">__:__:__</div><div class="np-hint" id="np-h">НАВ · ЧЧ:ММ:СС</div></div>
              <div class="npgrid">
                <div class="npb" onclick="npP('1')">1</div><div class="npb" onclick="npP('2')">2</div><div class="npb" onclick="npP('3')">3</div>
                <div class="npb" onclick="npP('4')">4</div><div class="npb" onclick="npP('5')">5</div><div class="npb" onclick="npP('6')">6</div>
                <div class="npb" onclick="npP('7')">7</div><div class="npb" onclick="npP('8')">8</div><div class="npb" onclick="npP('9')">9</div>
                <div class="npb clr" onclick="npClr()">Изчисти</div><div class="npb" onclick="npP('0')">0</div><div class="npb del" onclick="npDel()">⌫</div>
                <div class="npb ok" onclick="npSave()">✓ Запази</div>
              </div>
              <div id="t-lap-w" style="display:none;margin-bottom:7px">
                <label style="font-size:9px;color:var(--g2);text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:3px">Обиколка #</label>
                <input type="number" id="t-lap" value="1" min="1" style="width:100%;background:var(--bg2);border:1px solid var(--b2);border-radius:7px;padding:7px 10px;color:var(--w);font-size:14px;font-family:'Share Tech Mono',monospace;outline:none">
              </div>
              <div class="st-btns">
                <div class="stb dnf" onclick="setStatus('DNF')">⛔ DNF</div>
                <div class="stb dns" onclick="setStatus('DNS')">— DNS</div>
                <div class="stb dsq" onclick="setStatus('DSQ')">🚫 DSQ</div>
              </div>
            </div>
            <div class="msg" id="t-msg"></div>
          </div>
          <div class="col">
            <div class="sl">Последни записи</div>
            <div class="card">
              <table><thead><tr><th>№</th><th>Участник</th><th>Тип</th><th class="r">Резултат</th><th>Статус</th></tr></thead>
              <tbody id="recent"><tr><td colspan="5" class="empty-cell">Няма записи</td></tr></tbody></table>
            </div>
          </div>
        </div>
      </div>

      <!-- RIDERS -->
      <div class="pg" id="pg-riders">
        <div class="card">
          <div class="ch">
            <div class="ct">🏍️ Участници</div>
            <div style="display:flex;gap:7px;align-items:center">
              <input id="r-filter" placeholder="Търси..." style="background:var(--bg3);border:1px solid var(--b2);border-radius:7px;padding:4px 9px;color:var(--w);font-size:12px;outline:none;width:150px" oninput="filterR(this.value)">
              <div class="ca" onclick="nav('add-rider')">+ Нов</div>
            </div>
          </div>
          <table><thead><tr><th>№</th><th>Участник</th><th>Клуб</th><th>Мотор</th><th>Лиценз</th><th>Статус</th><th></th></tr></thead>
          <tbody id="r-body"><tr><td colspan="7" class="empty-cell">Зареждане...</td></tr></tbody></table>
        </div>
      </div>

      <!-- ADD RIDER -->
      <div class="pg" id="pg-add-rider">
        <div class="card" style="max-width:600px">
          <div class="ch"><div class="ct">➕ Нов Участник</div></div>
          <div style="padding:14px">
            <div class="fgrid3">
              <div class="fg"><label>Стартов номер *</label><input type="number" id="ar-num" placeholder="272" class="mono"></div>
              <div class="fg"><label>Собствено иme *</label><input id="ar-first" placeholder="Кристиан"></div>
              <div class="fg"><label>Фамилно иme *</label><input id="ar-last" placeholder="Петров"></div>
            </div>
            <div class="fgrid2">
              <div class="fg"><label>Клуб</label><input id="ar-club" placeholder="МСК Хард Райдърс"></div>
              <div class="fg"><label>Мотоциклет</label><input id="ar-moto" placeholder="KTM 300 EXC"></div>
            </div>
            <div class="fgrid3">
              <div class="fg"><label>Лицензен номер</label><input id="ar-lic" placeholder="БФМ-2025-272"></div>
              <div class="fg"><label>Статус на лиценза</label>
                <select id="ar-ls"><option value="Valid">✅ Валиден</option><option value="Expired">❌ Изтекъл</option><option value="Foreign">🌍 Чуждестранен</option><option value="Missing">— Без лиценз</option></select>
              </div>
              <div class="fg"><label>Държава</label>
                <select id="ar-co"><option value="BG">🇧🇬 България</option><option value="RS">🇷🇸 Сърбия</option><option value="RO">🇷🇴 Румъния</option><option value="GR">🇬🇷 Гърция</option><option value="MK">🇲🇰 Македония</option><option value="OTHER">🌍 Друго</option></select>
              </div>
            </div>
            <div class="brow"><div class="btn pr" onclick="addRider()">✓ Запиши</div><div class="btn sc" onclick="nav('riders')">Отказ</div></div>
            <div class="msg" id="ar-msg"></div>
          </div>
        </div>
      </div>

      <!-- PENALTIES -->
      <div class="pg" id="pg-penalties">
        <div class="card" style="max-width:600px;margin-bottom:12px">
          <div class="ch"><div class="ct">+ Ново Наказание</div></div>
          <div style="padding:13px">
            <div class="fgrid2">
              <div class="fg"><label>Участник</label><div class="rs-wrap"><div class="rs-icon">🔍</div><input id="p-search" placeholder="Номер..." oninput="searchR(this.value,'p')" autocomplete="off"><div class="rs-drop" id="p-drop"></div></div></div>
              <div class="fg"><label>Тип</label><select id="p-type"><option value="WrongRoute">🗺️ Отсечен маршрут</option><option value="DelayTP">⏰ Закъснение TP</option><option value="Equipment">⚙️ Оборудване</option><option value="DangerousDriving">⚠️ Опасно каране</option><option value="DSQ">🚫 Дисквалификация</option><option value="Other">📋 Друго</option></select></div>
            </div>
            <div class="fgrid2">
              <div class="fg"><label>Добавено Вреeme</label><input type="text" id="p-time" placeholder="00:05:00" class="mono"></div>
              <div class="fg"><label>Описание</label><input type="text" id="p-desc" placeholder="Отсечен маршрут при TP4"></div>
            </div>
            <div class="brow"><div class="btn pr" onclick="addPenalty()">+ Добави</div></div>
            <div class="msg" id="p-msg"></div>
          </div>
        </div>
        <div class="card">
          <div class="ch"><div class="ct">⚠️ Всички Наказания</div><div class="ca" onclick="loadPenalties()">⟳</div></div>
          <table><thead><tr><th>Участник</th><th>Тип</th><th>Вреeme</th><th>Описание</th><th>Статус</th><th></th></tr></thead>
          <tbody id="pen-body"><tr><td colspan="6" class="empty-cell">Зареждане...</td></tr></tbody></table>
        </div>
      </div>

      <!-- EVENTS -->
      <div class="pg" id="pg-events">
        <div class="card" style="max-width:600px;margin-bottom:12px">
          <div class="ch"><div class="ct">📅 Ново Събитие</div></div>
          <div style="padding:13px">
            <div class="fgrid2">
              <div class="fg"><label>Название *</label><input id="ev-name" placeholder="Хард Ендуро Бухово 2025"></div>
              <div class="fg"><label>Тип</label><select id="ev-type"><option value="Championship">🏆 Шампионат</option><option value="Free">🏁 Свободно</option></select></div>
            </div>
            <div class="fgrid2">
              <div class="fg"><label>Дата от</label><input type="date" id="ev-from"></div>
              <div class="fg"><label>Дата до</label><input type="date" id="ev-to"></div>
            </div>
            <div class="fg" style="margin-bottom:9px"><label>Място</label><input id="ev-loc" placeholder="Бухово, София"></div>
            <div class="brow"><div class="btn pr" onclick="addEvent()">🚀 Създай</div></div>
            <div class="msg" id="ev-msg"></div>
          </div>
        </div>
        <div class="card">
          <div class="ch"><div class="ct">📅 Всички Събития</div><div class="ca" onclick="loadEvents()">⟳</div></div>
          <table><thead><tr><th>Събитие</th><th>Тип</th><th>Дати</th><th>Статус</th><th></th></tr></thead>
          <tbody id="ev-body"><tr><td colspan="5" class="empty-cell">Зареждане...</td></tr></tbody></table>
        </div>
      </div>

    </div>
  </main>
</div>

<div class="toast" id="toast"></div>

<script>
const API='http://localhost:5048/api';
let EVENT_ID=1,allRiders=[],tMode='nav',tDigits=[],tRider=null,JWT=null;

// ── AUTH ──
async function doLogin(){
  const u=document.getElementById('l-user').value;
  const p=document.getElementById('l-pass').value;
  if(!u||!p)return;
  try{
    const r=await fetch(`${API}/auth/login`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:p})});
    if(r.ok){
      const d=await r.json();
      JWT=d.token;
      sessionStorage.setItem('jwt',JWT);
      document.getElementById('login-screen').style.display='none';
      document.getElementById('app').style.display='grid';
      initApp();
    }else{
      document.getElementById('l-err').style.display='block';
    }
  }catch{document.getElementById('l-err').style.display='block'}
}

function logout(){
  JWT=null;sessionStorage.removeItem('jwt');
  document.getElementById('app').style.display='none';
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('l-pass').value='';
  document.getElementById('l-err').style.display='none';
}

function authH(){return{headers:{'Content-Type':'application/json','Authorization':'Bearer '+JWT}}}

document.getElementById('l-pass').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin()});
document.getElementById('l-user').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('l-pass').focus()});

// Check session
const saved=sessionStorage.getItem('jwt');
if(saved){JWT=saved;document.getElementById('login-screen').style.display='none';document.getElementById('app').style.display='grid';initApp();}

// ── SignalR ──
const conn=new signalR.HubConnectionBuilder().withUrl('http://localhost:5048/hubs/race').withAutomaticReconnect().build();
conn.on('StandingsUpdated',d=>{renderStandings(d);setUpd();toast('📊 Класацията е обновена!')});
conn.on('PenaltyAdded',()=>{loadPenalties();toast('⚠️ Ново наказание!')});
conn.on('PenaltyConfirmed',()=>{loadStandings();toast('✅ Наказание потвърдено!')});
async function startSR(){try{await conn.start();await conn.invoke('JoinEvent',EVENT_ID);setConn(true)}catch{setConn(false);setTimeout(startSR,3000)}}
conn.onreconnected(()=>{conn.invoke('JoinEvent',EVENT_ID);setConn(true)});conn.onclose(()=>setConn(false));
function setConn(ok){document.getElementById('cdot').className='cdot'+(ok?' on':'');document.getElementById('ct').textContent=ok?'● Live':'○ Offline'}
function setUpd(){document.getElementById('last-up').textContent='Обновено: '+new Date().toLocaleTimeString('bg-BG')}

// ── INIT ──
function initApp(){loadEvent();loadRidersData();loadStandings();loadPenalties();startSR();}

// ── NAV ──
const pnames={standings:'🏆 Класация',timing:'⏱️ Въвеждане',riders:'🏍️ Участници','add-rider':'➕ Нов Участник',penalties:'⚠️ Наказания',events:'📅 Събития'};
function nav(n){
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('act'));
  document.querySelectorAll('.ni').forEach(ni=>ni.classList.remove('act'));
  const pg=document.getElementById('pg-'+n);if(pg)pg.classList.add('act');
  const ni=document.querySelector(`.ni[onclick*="'${n}'"]`);if(ni)ni.classList.add('act');
  document.getElementById('tb-title').textContent=pnames[n]||n;
  document.querySelector('.content').scrollTo(0,0);
  if(n==='riders')loadRiders();
  if(n==='penalties')loadPenalties();
  if(n==='events')loadEvents();
}

// ── DATA ──
async function loadEvent(){
  try{const r=await fetch(`${API}/events/${EVENT_ID}`);const e=await r.json();
  document.getElementById('sb-ev').textContent=e.name;document.getElementById('sb-loc').textContent=e.location;}catch{}
}
async function loadRidersData(){
  try{const r=await fetch(`${API}/events/${EVENT_ID}/riders`);allRiders=await r.json();document.getElementById('sb-cnt').textContent=allRiders.length;}catch{}
}
async function loadStandings(){
  try{
    const r=await fetch(`${API}/events/${EVENT_ID}/results/standings`);const d=await r.json();
    renderStandings(d);setUpd();
    document.getElementById('s-tot').textContent=d.length;
    document.getElementById('s-fin').textContent=d.filter(s=>s.status==='Finished').length;
    document.getElementById('s-dnx').textContent=d.filter(s=>s.status!=='Finished').length;
  }catch{}
}
async function loadRiders(){await loadRidersData();renderRiders(allRiders)}
async function loadPenalties(){
  try{
    const r=await fetch(`${API}/events/${EVENT_ID}/penalties`);const d=await r.json();
    renderPenalties(d);document.getElementById('s-pen').textContent=d.length;
    const pend=d.filter(p=>p.status==='Pending').length;
    const b=document.getElementById('sb-pen');b.textContent=pend;b.style.display=pend>0?'':'none';
  }catch{}
}
async function loadEvents(){
  try{const r=await fetch(`${API}/events`);const d=await r.json();renderEvents(d);}catch{}
}

// ── RENDER ──
const sm={Finished:['ok','✓ Finished'],DNF:['dnf','⛔ DNF'],DNS:['dns','— DNS'],DSQ:['dsq','🚫 DSQ']};
function fmt(t){return t?t.substring(0,8):'—'}

function renderStandings(d){
  const b=document.getElementById('st-body');
  if(!d?.length){b.innerHTML='<tr><td colspan="9" class="empty-cell">Няма резултати</td></tr>';return}
  b.innerHTML=d.map(s=>{
    const p=s.position,rc=p===1?'gold':p===2?'silver':p===3?'bronze':'',pc=p===1?'g':p===2?'s':p===3?'b':'x';
    const[sc,sl]=sm[s.status]||['dns',s.status];
    return`<tr class="${rc}"><td><span class="pos ${pc}">${p||'—'}</span></td><td><span class="rn">${s.rider.raceNumber}</span></td><td><div style="font-weight:700">${s.rider.firstName} ${s.rider.lastName}</div><div style="font-size:10px;color:var(--g2)">${s.rider.club||''}</div></td><td style="text-align:right"><span class="mo nav">${fmt(s.navTime)}</span></td><td style="text-align:right"><span class="mo xc">${fmt(s.xcTotal)}</span></td><td style="text-align:right"><span class="mo ss">${fmt(s.ssTotal)}</span></td><td style="text-align:right"><span class="mo pen">${s.penalties?fmt(s.penalties):'—'}</span></td><td style="text-align:right"><span class="mo total">${s.totalTime?fmt(s.totalTime):'—'}</span></td><td><span class="badge ${sc}">${sl}</span></td></tr>`;
  }).join('');
}

function renderRiders(d){
  const b=document.getElementById('r-body');
  if(!d?.length){b.innerHTML='<tr><td colspan="7" class="empty-cell">Няма участници</td></tr>';return}
  b.innerHTML=d.map(r=>`<tr><td><span class="rn">${r.raceNumber}</span></td><td style="font-weight:700">${r.firstName} ${r.lastName}</td><td style="font-size:11px;color:var(--g2)">${r.club||'—'}</td><td style="font-size:11px;color:var(--g2)">${r.motorcycle||'—'}</td><td style="font-size:10px;color:var(--g2);font-family:'Share Tech Mono',monospace">${r.licenseNumber||'—'}</td><td><span class="badge ${r.licenseStatus==='Valid'?'ok':r.licenseStatus==='Expired'?'dnf':'dns'}">${r.licenseStatus}</span></td><td><div style="display:flex;gap:4px"><div class="btn re sm" onclick="deleteRider(${r.id},${r.raceNumber})">✕</div></div></td></tr>`).join('');
}

function filterR(q){if(!q){renderRiders(allRiders);return}const lq=q.toLowerCase();renderRiders(allRiders.filter(r=>r.raceNumber.toString().includes(q)||r.firstName.toLowerCase().includes(lq)||r.lastName.toLowerCase().includes(lq)||(r.club||'').toLowerCase().includes(lq)))}

const penTypes={WrongRoute:'Отсечен маршрут',DelayTP:'Закъснение TP',Equipment:'Оборудване',DangerousDriving:'Опасно каране',DSQ:'Дисквалификация',Other:'Друго'};

function renderPenalties(d){
  const b=document.getElementById('pen-body');
  if(!d?.length){b.innerHTML='<tr><td colspan="6" class="empty-cell">Няма наказания</td></tr>';return}
  b.innerHTML=d.map(p=>`<tr><td><span class="rn">${p.rider?.raceNumber||'?'}</span> <span style="font-weight:700">${p.rider?.lastName||''}</span></td><td style="font-size:11px">${penTypes[p.type]||p.type}</td><td><span class="mo pen">${p.timeAdded||'—'}</span></td><td style="font-size:11px;color:var(--g2)">${p.description}</td><td><span class="badge ${p.status==='Confirmed'?'conf':p.status==='Rejected'?'dnf':'pen'}">${p.status==='Confirmed'?'✓ Потвърдено':p.status==='Rejected'?'✗ Отхвърлено':'⏳ Изчаква'}</span></td><td><div style="display:flex;gap:4px">${p.status==='Pending'?`<div class="btn gr sm" onclick="confirmPenalty(${p.id})">✓</div><div class="btn re sm" onclick="rejectPenalty(${p.id})">✕</div>`:''}</div></td></tr>`).join('');
}

function renderEvents(d){
  const b=document.getElementById('ev-body');
  if(!d?.length){b.innerHTML='<tr><td colspan="5" class="empty-cell">Няма събития</td></tr>';return}
  b.innerHTML=d.map(e=>`<tr><td><div style="font-weight:700">${e.name}</div><div style="font-size:10px;color:var(--g2)">${e.location}</div></td><td><span class="badge ${e.type==='Championship'?'ok':'dns'}">${e.type==='Championship'?'Шампионат':'Свободно'}</span></td><td style="font-size:11px;color:var(--g2)">${(e.dateFrom||'').substring(0,10)} — ${(e.dateTo||'').substring(0,10)}</td><td><span class="badge ${e.status==='Live'?'ok':'dns'}">${e.status}</span></td><td><div class="btn sc sm" onclick="switchEvent(${e.id},'${e.name}')">Избери</div></td></tr>`).join('');
}

// ── ACTIONS ──
async function addRider(){
  const num=document.getElementById('ar-num').value,first=document.getElementById('ar-first').value,last=document.getElementById('ar-last').value;
  if(!num||!first||!last){showMsg('ar-msg','⚠️ Попълни задължителните полета!',false);return}
  const body={raceNumber:parseInt(num),firstName:first,lastName:last,licenseNumber:document.getElementById('ar-lic').value||null,licenseStatus:document.getElementById('ar-ls').value,club:document.getElementById('ar-club').value||null,motorcycle:document.getElementById('ar-moto').value||null,country:document.getElementById('ar-co').value};
  try{
    const r=await fetch(`${API}/events/${EVENT_ID}/riders`,{method:'POST',...authH(),body:JSON.stringify(body)});
    if(r.ok){showMsg('ar-msg',`✅ Участник #${num} записан!`,true);['ar-num','ar-first','ar-last','ar-lic','ar-club','ar-moto'].forEach(id=>document.getElementById(id).value='');await loadRidersData();toast(`🏍️ #${num} ${last} добавен!`)}
    else{const err=await r.json();showMsg('ar-msg','❌ '+(err.message||err.error||'Грешка'),false)}
  }catch{showMsg('ar-msg','❌ Грешка',false)}
}

async function deleteRider(id,num){
  if(!confirm(`Изтрий #${num}?`))return;
  await fetch(`${API}/events/${EVENT_ID}/riders/${id}`,{method:'DELETE',...authH()});
  await loadRidersData();renderRiders(allRiders);toast(`🗑️ #${num} изтрит`);
}

async function addPenalty(){
  const search=document.getElementById('p-search').value,m=search.match(/^#?(\d+)/);
  if(!m){showMsg('p-msg','⚠️ Избери участник!',false);return}
  const desc=document.getElementById('p-desc').value;
  if(!desc){showMsg('p-msg','⚠️ Въведи описание!',false);return}
  const body={raceNumber:parseInt(m[1]),type:document.getElementById('p-type').value,timeAdded:document.getElementById('p-time').value||null,description:desc};
  try{
    const r=await fetch(`${API}/events/${EVENT_ID}/penalties`,{method:'POST',...authH(),body:JSON.stringify(body)});
    if(r.ok){showMsg('p-msg','✅ Наказанието е добавено!',true);document.getElementById('p-search').value='';document.getElementById('p-time').value='';document.getElementById('p-desc').value='';loadPenalties();toast('⚠️ Наказание добавено!')}
    else{const err=await r.json();showMsg('p-msg','❌ '+(err.error||'Грешка'),false)}
  }catch{showMsg('p-msg','❌ Грешка',false)}
}

async function confirmPenalty(id){await fetch(`${API}/events/${EVENT_ID}/penalties/${id}/confirm`,{method:'PUT',...authH()});loadPenalties();loadStandings()}
async function rejectPenalty(id){await fetch(`${API}/events/${EVENT_ID}/penalties/${id}/reject`,{method:'PUT',...authH()});loadPenalties()}

async function addEvent(){
  const name=document.getElementById('ev-name').value;if(!name){showMsg('ev-msg','⚠️ Въведи название!',false);return}
  const from=document.getElementById('ev-from').value||new Date().toISOString().split('T')[0];
  const to=document.getElementById('ev-to').value||from;
  const body={name,location:document.getElementById('ev-loc').value||'—',dateFrom:from+'T00:00:00Z',dateTo:to+'T00:00:00Z',type:document.getElementById('ev-type').value,requiresLicense:true,requiresClub:false,isPublic:true};
  try{const r=await fetch(`${API}/events`,{method:'POST',...authH(),body:JSON.stringify(body)});if(r.ok){showMsg('ev-msg','✅ Събитието е създадено!',true);loadEvents();toast('📅 Ново събитие!')}else{showMsg('ev-msg','❌ Грешка',false)}}catch{showMsg('ev-msg','❌ Грешка',false)}
}

function switchEvent(id,name){EVENT_ID=id;document.getElementById('sb-ev').textContent=name;loadEvent();loadRidersData();loadStandings();conn.invoke('JoinEvent',id);nav('standings');toast('📅 '+name)}

async function setFlag(flag){
  document.querySelectorAll('.fbtn').forEach(b=>b.classList.remove('active'));document.getElementById('flag-'+flag)?.classList.add('active');
  try{await fetch(`${API}/events/${EVENT_ID}/flag`,{method:'PUT',...authH(),body:JSON.stringify({flag})});const e={Green:'🟢',Yellow:'🟡',Red:'🔴',Black:'⬛'};toast(e[flag]+' '+flag+' знаме!')}catch{}
}

// ── TIMING ──
function setTMode(m,el){
  tMode=m;tDigits=[];
  document.querySelectorAll('.mode-tabs .mtab').forEach(t=>t.classList.remove('act'));el.classList.add('act');
  npUpd();document.getElementById('t-lap-w').style.display=m!=='nav'?'block':'none';
  const L={nav:['rgba(59,130,246,.06)','rgba(59,130,246,.14)','var(--bl)','🧭 Режим: Навигация'],xc:['rgba(249,115,22,.06)','rgba(249,115,22,.14)','var(--or)','🏁 Режим: XC Обиколка'],ss:['rgba(168,85,247,.06)','rgba(168,85,247,.14)','var(--pu)','⏱️ Режим: SS']};
  const[bg,bc,c,t]=L[m];const l=document.getElementById('tmode-lbl');l.style.background=bg;l.style.borderColor=bc;l.style.color=c;l.textContent=t;
  document.getElementById('np-h').textContent=m==='nav'?'НАВ · ЧЧ:ММ:СС':m==='xc'?'XC · ММ:СС':'SS · ММ:СС';
}

function npP(d){if(tDigits.length>=6)return;tDigits.push(d);npUpd()}
function npDel(){tDigits.pop();npUpd()}
function npClr(){tDigits=[];npUpd()}
function npUpd(){
  const el=document.getElementById('np-t'),d=[...tDigits];
  if(tMode==='nav'){while(d.length<6)d.unshift('_');el.textContent=`${d[0]}${d[1]}:${d[2]}${d[3]}:${d[4]}${d[5]}`}
  else{while(d.length<6)d.unshift('_');el.textContent=`${d[0]}${d[1]}:${d[2]}${d[3]}.${d[4]}${d[5]}`}
  el.className='np-time'+(tDigits.length===0?' empty':'');
}

async function npSave(){
  if(!tRider){showMsg('t-msg','⚠️ Избери участник!',false);return}
  if(tDigits.length<4){showMsg('t-msg','⚠️ Въведи пълно вреeme!',false);return}
  const d=[...tDigits];while(d.length<6)d.push('0');
  let ts=tMode==='nav'?`${d[0]}${d[1]}:${d[2]}${d[3]}:${d[4]}${d[5]}`:`00:${d[0]}${d[1]}:${d[2]}${d[3]}`;
  const tm={nav:'Navigation',xc:'XCLap',ss:'SpecialStage'};const lap=document.getElementById('t-lap').value;
  const body={raceNumber:tRider,type:tm[tMode],time:ts,status:'Finished',segmentName:tMode==='nav'?'Nav':tMode==='xc'?'XC':`SS${lap}`,lapNumber:tMode!=='nav'?parseInt(lap):null};
  try{
    const r=await fetch(`${API}/events/${EVENT_ID}/results`,{method:'POST',...authH(),body:JSON.stringify(body)});
    if(r.ok){showMsg('t-msg',`✅ Записан #${tRider}!`,true);addRecent(tRider,tm[tMode],ts);tDigits=[];npUpd();loadStandings()}
    else{const e=await r.json();showMsg('t-msg','❌ '+(e.error||'Грешка'),false)}
  }catch{showMsg('t-msg','❌ Грешка',false)}
}

async function setStatus(status){
  if(!tRider){showMsg('t-msg','⚠️ Избери участник!',false);return}
  const tm={nav:'Navigation',xc:'XCLap',ss:'SpecialStage'};
  try{await fetch(`${API}/events/${EVENT_ID}/results/rider/${tRider}/status`,{method:'PUT',...authH(),body:JSON.stringify({type:tm[tMode],status})});showMsg('t-msg',`✅ ${status} за #${tRider}!`,true);loadStandings()}catch{showMsg('t-msg','❌ Грешка',false)}
}

function addRecent(num,type,time){
  const b=document.getElementById('recent');const rider=allRiders.find(r=>r.raceNumber===num);const name=rider?`${rider.firstName} ${rider.lastName}`:'—';
  const tl={Navigation:'🧭',XCLap:'🏁',SpecialStage:'⏱️'};
  const row=document.createElement('tr');row.innerHTML=`<td><span class="rn">${num}</span></td><td style="font-size:11px">${name}</td><td style="font-size:10px">${tl[type]||type}</td><td style="text-align:right"><span class="mo">${time}</span></td><td><span class="badge ok">✓</span></td>`;
  const em=b.querySelector('td[colspan]');if(em)b.innerHTML='';b.insertBefore(row,b.firstChild);if(b.children.length>8)b.removeChild(b.lastChild);
}

// ── SEARCH ──
function searchR(val,prefix){
  const drop=document.getElementById(prefix+'-drop');
  if(!val||val.length<1){drop.style.display='none';return}
  const q=val.toLowerCase();const matches=allRiders.filter(r=>r.raceNumber.toString().startsWith(val)||r.firstName.toLowerCase().includes(q)||r.lastName.toLowerCase().includes(q)).slice(0,6);
  if(!matches.length){drop.style.display='none';return}
  drop.innerHTML=matches.map(r=>`<div class="rs-item" onclick="selRider(${r.raceNumber},'${r.firstName} ${r.lastName}','${prefix}')"><span class="rn" style="font-size:10px;min-width:30px">${r.raceNumber}</span><span>${r.firstName} ${r.lastName}</span><span style="font-size:10px;color:var(--g2);margin-left:auto">${r.club||''}</span></div>`).join('');
  drop.style.display='block';
}

function selRider(num,name,prefix){
  document.getElementById(prefix+'-search').value=`#${num} ${name}`;
  document.getElementById(prefix+'-drop').style.display='none';
  if(prefix==='t'){tRider=num;document.getElementById('np-r').textContent=`#${num} · ${name}`}
}

document.addEventListener('click',e=>{if(!e.target.closest('.rs-wrap'))document.querySelectorAll('.rs-drop').forEach(d=>d.style.display='none')});

// ── HELPERS ──
function showMsg(id,text,ok){const el=document.getElementById(id);el.textContent=text;el.className='msg '+(ok?'ok':'err');clearTimeout(el._t);el._t=setTimeout(()=>el.className='msg',3000)}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2800)}
</script>
</body>
</html>
